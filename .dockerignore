# VCS
.git/
.github/
.gitignore
.gitattributes

# Python build / test artifacts
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
coverage.xml
htmlcov/
build/
dist/

# Editor / OS noise
.idea/
.vscode/
*.swp
.DS_Store

# Local development
debug_model.py
vba_report.json
.semantic_release_templates/

# Tests / docs / tools — not needed at runtime, but README.md *is*
# referenced by pyproject.toml (`readme = "README.md"`) so it has to
# stay in the build context for `python -m build` to succeed.
tests/
docs/
tools/
CHANGELOG.md
